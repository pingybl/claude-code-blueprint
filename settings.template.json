{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "cleanupPeriodDays": 30,
  "env": {
    "BASH_DEFAULT_TIMEOUT_MS": "300000",
    "MAX_MCP_OUTPUT_TOKENS": "25000"
  },
  "permissions": {
    "allow": [
      "Read",
      "Grep",
      "Glob",
      "Bash(git:*)",
      "Bash(ls:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(wc:*)",
      "Bash(du:*)",
      "Bash(which:*)",
      "Bash(echo:*)",
      "Bash(pwd:*)",
      "Bash(date:*)",
      "Bash(tree:*)",
      "Bash(jq:*)",
      "Bash(gh:*)",
      "WebSearch",
      "WebFetch",

      "__ ADD YOUR PACKAGE MANAGERS __": "__ EXAMPLES BELOW __",
      "Bash(uv:*)":        "Python (uv)",
      "Bash(npm run:*)":   "Node.js",
      "Bash(npm test:*)":  "Node.js",
      "Bash(npm install:*)": "Node.js",
      "Bash(pnpm:*)":      "Node.js (pnpm)",
      "Bash(yarn:*)":      "Node.js (yarn)",
      "Bash(npx:*)":       "Node.js",
      "Bash(cargo:*)":     "Rust",

      "__ ADD YOUR LINTERS __": "__ EXAMPLES BELOW __",
      "Bash(ruff:*)":      "Python linter",
      "Bash(mypy:*)":      "Python type checker",
      "Bash(pytest:*)":    "Python tests",
      "Bash(python:*)":    "Python runtime",

      "__ ADD YOUR MCP SERVERS __": "__ EXAMPLES BELOW __",
      "mcp__context7__*":  "Documentation lookup",
      "mcp__fetch__*":     "URL fetching",
      "mcp__git__*":       "Git operations"
    ],
    "deny": [
      "Bash(sudo:*)",
      "Bash(su :*)",
      "Bash(/usr/bin/sudo:*)",
      "Bash(doas :*)",
      "Bash(pkexec:*)",
      "Bash(chmod 777:*)",
      "Bash(chmod -R 777:*)",
      "Bash(:|:*)",
      "Bash(mkfs:*)",
      "Bash(dd if:*)",
      "Bash(> /dev:*)",
      "Bash(eval :*)",
      "Bash(crontab:*)",
      "Bash(nohup:*)",
      "Bash(nc :*)",
      "Bash(ncat:*)",
      "Bash(socat:*)",

      "Write(/etc/*)",
      "Write(/usr/*)",
      "Write(/System/*)",
      "Write(/var/*)",
      "Write(/bin/*)",
      "Write(/sbin/*)",
      "Write(~/.ssh/*)",
      "Write(*.pem)",
      "Write(*id_rsa*)",
      "Write(*id_ed25519*)",
      "Write(*.key)",
      "Write(.env.production)",
      "Write(*credentials*)",
      "Write(*secret*)",

      "Edit(~/.ssh/*)",
      "Edit(*.pem)",
      "Edit(*id_rsa*)",
      "Edit(*id_ed25519*)",
      "Edit(.env.production)",
      "Edit(*credentials*)",
      "Edit(*secret*)"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/scripts/session-start.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/scripts/session-end.sh",
            "timeout": 3
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/scripts/user-prompt-secrets.sh",
            "timeout": 2
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/scripts/write-guard.sh",
            "timeout": 3
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/scripts/bash-guard.sh",
            "timeout": 3
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/scripts/write-format.sh",
            "timeout": 15
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/scripts/bash-vuln.sh",
            "timeout": 3
          }
        ]
      }
    ],
    "PostToolUseFailure": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/scripts/posttooluse-failure.sh",
            "timeout": 3
          }
        ]
      }
    ],
    "PermissionRequest": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/scripts/permission-git.sh",
            "timeout": 2
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/scripts/stop.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/scripts/pre-compact.sh",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
